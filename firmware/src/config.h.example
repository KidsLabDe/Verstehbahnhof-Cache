#pragma once

// Kopiere diese Datei nach config.h und trage echte Werte ein.
// config.h ist in .gitignore und wird nicht eingecheckt.

// --- WLAN ---
#define WIFI_SSID       "DEIN_WLAN"
#define WIFI_PASSWORD   "DEIN_PASSWORT"

// --- API (MatzE) ---
// Liefert den aktuellen Zustand der Reise als JSON, z.B.:
//   { "currentStation": 2, "totalStations": 5 }
#define API_URL         "http://verstehbahnhof-cache.local/api/status"
// Die Firmware pollt nicht mehr zeitgesteuert: der API-Call passiert
// nur dann, wenn der Zug am nächsten (roten) Bahnhof angekommen ist.
// Der HTTP-Timeout sollte trotzdem kurz sein, sonst "hängt" der Zug am
// Wendepunkt sichtbar bis zur Antwort.
#define API_TIMEOUT_MS  1500

// --- NeoPixel ---
// D2 am Wemos D1 Mini (Lite) == GPIO4 (sicherer Pin, keine Boot-Konflikte)
#define NEOPIXEL_PIN    D2
#define NEOPIXEL_COUNT  30      // LEDs auf dem Streifen insgesamt
#define NEOPIXEL_BRIGHTNESS 80  // 0..255

// Wie schnell der Zug zwischen zwei Bahnhöfen pendelt (ms pro LED-Schritt).
// Kleinere Zahl = schneller. 18 ≈ 55 fps.
#define TRAIN_FRAME_MS  18

// Anzahl Waggons hinter der Lok (dunkler werdendes Blau)
#define NUM_WAGONS      3

// Die Bahnhöfe selbst (Namen + Reihenfolge) stehen in main.cpp in
// STATION_NAMES[]. Die Positionen auf dem Streifen werden automatisch
// gleichmäßig verteilt – du musst hier nur NEOPIXEL_COUNT korrekt setzen.
